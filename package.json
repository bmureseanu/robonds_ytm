{
  "name": "bvb-ytm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p . && node scripts/copy-static.mjs",
    "build:data": "tsx src/build-data.ts && node scripts/copy-static.mjs",
    "start": "node dist/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --update-env",
    "cli": "tsx src/cli.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^5.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
