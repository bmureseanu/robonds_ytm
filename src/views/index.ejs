<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="<%= appShortName %>" />
  <link rel="manifest" href="<%= manifestPath %>" />
  <link rel="icon" type="image/svg+xml" href="<%= iconPath %>" />
  <link rel="apple-touch-icon" href="<%= iconPath %>" />
  <title><%= appTitle %></title>
  <style>
    :root {
      --bg: #ffffff;
      --panel: #f6f7f9;
      --panel2: #eef1f6;
      --border: #d6dbe3;
      --text: #1a1d24;
      --muted: #5b6473;
      --accent: #2563eb;
      --good: #15803d;
      --bad: #b91c1c;
      --warn: #b45309;
      --warn-bg: rgba(180, 83, 9, 0.08);
    }
    * { box-sizing: border-box; }
    html, body { background: var(--bg); color: var(--text); margin: 0; font: 14px/1.4 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left); }
    @media (max-width: 700px) {
      header { padding: 10px 12px; }
      header h1 { font-size: 14px; }
      main { padding: 10px 6px; overflow-x: auto; }
      table { font-size: 12px; }
      thead th, tbody td { padding: 5px 6px; }
    }
    header {
      padding: 14px 20px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
      background: var(--panel);
    }
    header h1 { font-size: 16px; margin: 0; font-weight: 600; }
    .meta { color: var(--muted); font-size: 12px; }
    button {
      background: var(--panel2); color: var(--text); border: 1px solid var(--border);
      padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 13px;
    }
    button:hover { border-color: var(--accent); color: var(--accent); }
    button:disabled { opacity: 0.5; cursor: not-allowed; }
    .filters { display: flex; gap: 14px; align-items: center; }
    .filters label { color: var(--muted); font-size: 12px; display: flex; align-items: center; gap: 6px; }
    .filters input[type="checkbox"] { accent-color: var(--accent); }
    .filters input[type="number"] {
      width: 70px; background: var(--panel2); color: var(--text);
      border: 1px solid var(--border); border-radius: 4px; padding: 3px 6px;
    }
    .filter-target {
      color: var(--text) !important; font-weight: 600; font-size: 13px !important;
      padding: 2px 10px; border-left: 1px solid var(--border);
    }
    .filter-target input[type="number"] {
      width: 80px; font-size: 14px; padding: 4px 6px;
      border-color: var(--accent);
    }
    .price-buy   { color: var(--good); font-weight: 700; }
    .price-spread { color: var(--text); }
    .price-aggressive { color: var(--bad); }
    .badge {
      display: inline-block; margin-left: 4px; padding: 0 5px;
      border-radius: 3px; font-size: 10px; font-weight: 600;
      vertical-align: 1px;
    }
    .badge.ok { background: rgba(21,128,61,0.12); color: var(--good); }
    .badge.bad { background: rgba(185,28,28,0.12); color: var(--bad); }
    .badge.mid { background: rgba(180,83,9,0.12); color: var(--warn); }
    nav.tabs {
      display: flex; gap: 2px; padding: 12px 20px 0;
      background: var(--bg); border-bottom: 1px solid var(--border);
    }
    .tab {
      background: transparent; color: var(--muted);
      border: 1px solid transparent; border-bottom: none;
      border-radius: 6px 6px 0 0; padding: 8px 16px;
      cursor: pointer; font-size: 13px; font-weight: 600;
      margin-bottom: -1px;
    }
    .tab:hover:not(.active) { color: var(--accent); }
    .tab.active {
      background: var(--bg); color: var(--text);
      border-color: var(--border); border-bottom-color: var(--bg);
    }
    .tab .count {
      color: var(--muted); margin-left: 6px;
      font-weight: 400; font-size: 11px;
    }
    .tab.active .count { color: var(--accent); }
    main { padding: 16px 20px; }
    table { border-collapse: collapse; width: 100%; font-size: 13px; }
    thead th {
      position: sticky; top: 0; background: var(--panel); cursor: pointer; user-select: none;
      text-align: right; padding: 8px 10px; border-bottom: 1px solid var(--border);
      font-weight: 600; color: var(--muted); white-space: nowrap;
    }
    thead th.text-left { text-align: left; }
    thead th:hover { color: var(--accent); }
    thead th .arrow { color: var(--accent); margin-left: 4px; }
    tbody td {
      padding: 6px 10px; border-bottom: 1px solid var(--border);
      text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap;
    }
    tbody td.text-left { text-align: left; }
    tbody tr:hover { background: var(--panel2); }
    tbody tr.warn { background: var(--warn-bg); }
    tbody tr.warn td:first-child::before { content: "⚠ "; color: var(--warn); }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .yield { font-weight: 600; }
    .yield.best { color: var(--good); }
    .empty, .error { padding: 30px; text-align: center; color: var(--muted); }
    .error { color: var(--bad); }
    .pct-pos { color: var(--good); }
    .pct-neg { color: var(--bad); }
    .small { color: var(--muted); font-size: 11px; }
    footer { padding: 12px 20px; color: var(--muted); font-size: 11px; border-top: 1px solid var(--border); }
  </style>
</head>
<body>
  <header>
    <h1>BVB Titluri de stat — YTM at ask, bid &amp; last</h1>
    <button id="refresh">Refresh</button>
    <span class="meta" id="meta">loading…</span>
    <div class="filters">
      <label><input type="checkbox" id="requireAsk" checked /> only with ask</label>
      <label>min ask vol <input type="number" id="minAskVol" value="0" min="0" step="1" /></label>
      <label>max yrs <input type="number" id="maxYears" value="20" min="0" step="0.5" /></label>
      <label class="filter-target">
        Target YTM
        <input type="number" id="targetYtm" placeholder="e.g. 8.0" step="0.05" min="-50" max="50" inputmode="decimal" />
        %
      </label>
    </div>
  </header>
  <nav class="tabs" id="tabs" role="tablist">
    <button class="tab active" data-currency="RON" role="tab">RON <span class="count" id="count-RON">–</span></button>
    <button class="tab" data-currency="EUR" role="tab">EUR <span class="count" id="count-EUR">–</span></button>
  </nav>
  <main>
    <div id="content" class="empty">Loading…</div>
  </main>
  <footer>
    Source: <a href="https://m.bvb.ro/FinancialInstruments/Markets/Bonds" target="_blank" rel="noopener">m.bvb.ro</a>.
    Both RON and EUR Titluri de stat are scraped in the same pass and split into the two tabs.
    Prices are delayed ≥15 min by BVB and additionally refreshed on a 15-min cron.
    YTM at ask/bid/last computed locally assuming annual coupons (ACT/365);
    BVB YTM column reproduces the site's displayed YTM (based on last price) for cross-check.
    Type a target in "Target YTM" to see the clean price each bond needs to offer that yield —
    badge tells you whether the market is already there (<span class="badge ok">buy now</span>),
    your target sits inside the spread (<span class="badge mid">in spread</span>), or you'd be
    bidding below current buyers (<span class="badge bad">below bid</span>).
    Refresh = re-fetch the latest published data.json.
  </footer>

  <script>
    const DATA_URL = <%- JSON.stringify(dataPath) %>;
    const SERVICE_WORKER_URL = <%- JSON.stringify(swPath) %>;
    const $ = (id) => document.getElementById(id);
    let DATA = null;
    let sort = { key: "ytmAtAsk", dir: "desc" };
    let targetYtm = null;
    const SUPPORTED_CURRENCIES = ["RON", "EUR"];
    let currency = SUPPORTED_CURRENCIES.includes(location.hash.slice(1))
      ? location.hash.slice(1)
      : "RON";

    function priceAtYtm(yTarget, cfs, accrued) {
      if (yTarget == null || !cfs || !cfs.length) return null;
      const one = 1 + yTarget;
      if (one <= 0) return null;
      let dirty = 0;
      for (const cf of cfs) dirty += cf.amount / Math.pow(one, cf.years);
      const clean = dirty - (accrued || 0);
      return Number.isFinite(clean) ? clean : null;
    }

    function priceAtTargetCell(a) {
      const p = priceAtYtm(targetYtm, a.cashflows, a.accrued);
      if (p == null) return targetYtm == null ? '<span class="small">set target</span>' : "-";
      let cls = "price-spread";
      let badge = "";
      if (a.ask != null && p >= a.ask) {
        cls = "price-buy";
        badge = '<span class="badge ok">buy now</span>';
      } else if (a.bid != null && p < a.bid) {
        cls = "price-aggressive";
        badge = '<span class="badge bad">below bid</span>';
      } else if (a.ask != null && a.bid != null) {
        badge = '<span class="badge mid">in spread</span>';
      }
      return `<span class="${cls}">${p.toFixed(4)}</span>${badge}`;
    }

    function priceTargetLabel() {
      return targetYtm != null
        ? `Price @ ${(targetYtm * 100).toFixed(2)}%`
        : "Price @ target";
    }

    const COLUMNS = [
      { key: "ticker", label: "Ticker", align: "left", fmt: (a) =>
          `<a href="https://m.bvb.ro/FinancialInstruments/Details/FinancialInstrumentsDetails.aspx?s=${a.ticker}" target="_blank">${a.ticker}</a><div class="small">${a.isin}</div>` },
      { key: "maturity", label: "Maturity", align: "right", fmt: (a) => a.maturity || "-" },
      { key: "yearsToMaturity", label: "Yrs", align: "right", fmt: (a) => fmtNum(a.yearsToMaturity, 2) },
      { key: "couponPct", label: "Coupon", align: "right", fmt: (a) => fmtPct1(a.couponPct) },
      { key: "bid", label: "Bid", align: "right", fmt: (a) => fmtNum(a.bid, 4) + sub(a.bidVol) },
      { key: "ask", label: "Ask", align: "right", fmt: (a) => fmtNum(a.ask, 4) + sub(a.askVol) },
      { key: "lastPrice", label: "Last", align: "right", fmt: (a) => fmtNum(a.lastPrice, 4) },
      { key: "priceAtTarget", label: priceTargetLabel, align: "right", fmt: priceAtTargetCell },
      { key: "accrued", label: "Accrued", align: "right", fmt: (a) => fmtNum(a.accrued, 3) },
      { key: "dirtyAsk", label: "Dirty (ask)", align: "right", fmt: (a) => fmtNum(a.dirtyAsk, 3) },
      { key: "ytmAtAsk", label: "YTM ask", align: "right", fmt: (a) => yieldCell(a.ytmAtAsk, true) },
      { key: "ytmAtBid", label: "YTM bid", align: "right", fmt: (a) => yieldCell(a.ytmAtBid, false) },
      { key: "ytmAtLast", label: "YTM last", align: "right", fmt: (a) => yieldCell(a.ytmAtLast, false) },
      { key: "bvbYtm", label: "BVB YTM", align: "right", fmt: (a) => yieldCell(a.bvbYtm, false) },
    ];

    function sortValue(a, key) {
      if (key === "priceAtTarget") return priceAtYtm(targetYtm, a.cashflows, a.accrued);
      return a[key];
    }

    function sub(v) {
      if (v == null) return "";
      return `<div class="small">vol ${fmtNum(v, 0)}</div>`;
    }
    function fmtNum(x, d) { return x == null ? "-" : x.toFixed(d); }
    function fmtPct1(x) { return x == null ? "-" : x.toFixed(2) + "%"; }
    function yieldCell(y, best) {
      if (y == null) return "-";
      const cls = best ? "yield best" : "yield";
      const sign = y < 0 ? "pct-neg" : "pct-pos";
      return `<span class="${cls} ${sign}">${(y * 100).toFixed(3)}%</span>`;
    }

    async function load(force = false) {
      $("refresh").disabled = true;
      $("meta").textContent = "loading…";
      try {
        const url = DATA_URL + (force ? "?t=" + Date.now() : "");
        const res = await fetch(url, force ? { cache: "reload" } : {});
        if (!res.ok) throw new Error("HTTP " + res.status);
        DATA = await res.json();
        const at = new Date(DATA.generatedAt);
        const ageMin = Math.max(0, Math.round((Date.now() - at.getTime()) / 60000));
        $("meta").innerHTML = `${DATA.analytics.length} bonds — generated ${at.toLocaleString()} <span class="small">(${ageMin}m ago)</span>`;
        updateTabCounts();
        render();
      } catch (e) {
        $("content").innerHTML = `<div class="error">Failed to load: ${e.message || e}</div>`;
      } finally {
        $("refresh").disabled = false;
      }
    }

    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register(SERVICE_WORKER_URL).catch(() => {});
      });
    }

    function applyFilters(rows) {
      const requireAsk = $("requireAsk").checked;
      const minVol = Number($("minAskVol").value) || 0;
      const maxYears = Number($("maxYears").value) || Infinity;
      return rows.filter((a) =>
        a.currency === currency &&
        (!requireAsk || (a.ask != null && a.ytmAtAsk != null)) &&
        ((a.askVol ?? 0) >= minVol) &&
        (a.yearsToMaturity <= maxYears)
      );
    }

    function updateTabCounts() {
      if (!DATA) return;
      const counts = {};
      for (const a of DATA.analytics) counts[a.currency] = (counts[a.currency] || 0) + 1;
      for (const ccy of SUPPORTED_CURRENCIES) {
        const el = $("count-" + ccy);
        if (el) el.textContent = "(" + (counts[ccy] || 0) + ")";
      }
    }

    function setCurrency(ccy) {
      if (!SUPPORTED_CURRENCIES.includes(ccy) || ccy === currency) return;
      currency = ccy;
      document.querySelectorAll(".tab").forEach((t) =>
        t.classList.toggle("active", t.dataset.currency === ccy)
      );
      if (location.hash.slice(1) !== ccy) {
        history.replaceState(null, "", "#" + ccy);
      }
      render();
    }

    function applySort(rows) {
      const { key, dir } = sort;
      const factor = dir === "asc" ? 1 : -1;
      return [...rows].sort((a, b) => {
        const av = sortValue(a, key), bv = sortValue(b, key);
        if (av == null && bv == null) return 0;
        if (av == null) return 1;
        if (bv == null) return -1;
        if (typeof av === "string") return av.localeCompare(bv) * factor;
        return (av - bv) * factor;
      });
    }

    function render() {
      if (!DATA) return;
      const rows = applySort(applyFilters(DATA.analytics));
      if (!rows.length) {
        $("content").innerHTML = `<div class="empty">No rows match current filters.</div>`;
        return;
      }
      const isWarn = (a) =>
        a.ask == null || (a.ytmAtAsk != null && a.ytmAtAsk < 0);

      const ths = COLUMNS.map((c) => {
        const arrow = sort.key === c.key ? `<span class="arrow">${sort.dir === "asc" ? "▲" : "▼"}</span>` : "";
        const label = typeof c.label === "function" ? c.label() : c.label;
        return `<th class="text-${c.align}" data-key="${c.key}">${label}${arrow}</th>`;
      }).join("");

      const trs = rows.map((a) => {
        const tds = COLUMNS.map((c) => `<td class="text-${c.align}">${c.fmt(a)}</td>`).join("");
        return `<tr class="${isWarn(a) ? "warn" : ""}">${tds}</tr>`;
      }).join("");

      $("content").innerHTML = `<table><thead><tr>${ths}</tr></thead><tbody>${trs}</tbody></table>`;

      document.querySelectorAll("thead th").forEach((th) => {
        th.addEventListener("click", () => {
          const k = th.dataset.key;
          if (sort.key === k) sort.dir = sort.dir === "asc" ? "desc" : "asc";
          else { sort.key = k; sort.dir = (k === "ticker" || k === "maturity") ? "asc" : "desc"; }
          render();
        });
      });
    }

    $("refresh").addEventListener("click", () => load(true));
    ["requireAsk", "minAskVol", "maxYears"].forEach((id) => {
      $(id).addEventListener("change", render);
      $(id).addEventListener("input", render);
    });
    $("targetYtm").addEventListener("input", (e) => {
      const v = e.target.value.trim();
      const n = v === "" ? NaN : Number(v);
      targetYtm = Number.isFinite(n) ? n / 100 : null;
      render();
    });
    document.querySelectorAll(".tab").forEach((t) =>
      t.addEventListener("click", () => setCurrency(t.dataset.currency))
    );
    document.querySelectorAll(".tab").forEach((t) =>
      t.classList.toggle("active", t.dataset.currency === currency)
    );
    window.addEventListener("hashchange", () => {
      const h = location.hash.slice(1);
      if (SUPPORTED_CURRENCIES.includes(h)) setCurrency(h);
    });
    load();
  </script>
</body>
</html>